PORT=5001
MONGODB_URI=mongodb://localhost:27017/skillswap
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# VideoSDK (use API_KEY + SECRET_KEY for backend token generation)
VIDEOSDK_API_KEY=your_videosdk_api_key
VIDEOSDK_SECRET_KEY=your_videosdk_secret_key
# Optional: directly use a pre-generated token instead of API_KEY/SECRET_KEY
VIDEOSDK_AUTH_TOKEN=your_videosdk_auth_token

